# =============================================================
# Shifa (شفاء) — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================

# ── Supabase (required) ──────────────────────────────────────
# Server-side admin client (bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side (public, safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── OpenAI (optional — AI matching & wellness insights) ──────
OPENAI_API_KEY=sk-...

# ── Firebase (optional — push notifications) ─────────────────
# Server-side (service account JSON, single-line or base64)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Client-side Vite vars
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── Payment webhook HMAC verification (optional) ─────────────
FLOUCI_WEBHOOK_SECRET=
KONNECT_WEBHOOK_SECRET=

# ── Server port (optional, defaults to 5000) ─────────────────
# PORT=5000

# ── Supabase redirect URLs (configure in Supabase dashboard) ─
# Authentication → URL Configuration → Redirect URLs:
#   https://yourdomain.com/reset-password
#   https://yourdomain.com/verify-email
